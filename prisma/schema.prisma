generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String           @id @default(uuid())
  email                  String           @unique
  name                   String?
  targetIelts            Float?
  targetTestDaf          String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  activeReaderModule     String?
  activeReaderText       String?
  avatarUrl              String?
  bannerColor            String?          @default("#6366f1")
  activeReaderHighlights Int[]            @default([])
  friendCode             String?          @unique
  lastActive             DateTime?        @default(now())
  isBanned               Boolean          @default(false)
  banReason              String?
  englishDecks           EnglishDeck[]
  englishSessions        EnglishSession[]
  englishWords           EnglishWord[]
  friendshipsAsUser1     Friendship[]     @relation("friendshipUser1")
  friendshipsAsUser2     Friendship[]     @relation("friendshipUser2")
  germanDecks            GermanDeck[]
  germanSessions         GermanSession[]
  germanWords            GermanWord[]
  mathLogs               MathLog[]
  mathSessions           MathSession[]
  messagesReceived       Message[]        @relation("messagesReceived")
  messagesSent           Message[]        @relation("messagesSent")
  organizerHabits        OrganizerHabit[]
  organizerTasks         OrganizerTask[]
  practiceLogs           PracticeLog[]
  savedTexts             SavedText[]
  systemLogs             SystemLog[]
}

model Friendship {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user1     User     @relation("friendshipUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User     @relation("friendshipUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("messagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("messagesSent", fields: [senderId], references: [id], onDelete: Cascade)
}

model SavedText {
  id         String   @id @default(uuid())
  userId     String
  title      String
  content    String
  module     String
  createdAt  DateTime @default(now())
  highlights Int[]    @default([])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EnglishDeck {
  id          String        @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  words       EnglishWord[]
}

model EnglishWord {
  id                 String      @id @default(uuid())
  userId             String
  deckId             String
  term               String
  translation        String?
  transcription      String?
  context            String?
  contextTranslation String?
  mnemonic           String?
  partOfSpeech       String?
  clozeSentence      String?
  nextReview         DateTime    @default(now())
  interval           Float       @default(0)
  easiness           Float       @default(2.5)
  srsStep            Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deck               EnglishDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EnglishSession {
  id           String    @id @default(uuid())
  userId       String
  startTime    DateTime  @default(now())
  endTime      DateTime?
  durationMins Int?
  focusScore   Int?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GermanDeck {
  id          String       @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  words       GermanWord[]
}

model GermanWord {
  id                 String     @id @default(uuid())
  userId             String
  deckId             String
  term               String
  article            String?
  pluralForm         String?
  translation        String?
  context            String?
  contextTranslation String?
  mnemonic           String?
  partOfSpeech       String?
  clozeSentence      String?
  nextReview         DateTime   @default(now())
  interval           Float      @default(0)
  easiness           Float      @default(2.5)
  srsStep            Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deck               GermanDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GermanSession {
  id           String    @id @default(uuid())
  userId       String
  startTime    DateTime  @default(now())
  endTime      DateTime?
  durationMins Int?
  focusScore   Int?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MathLog {
  id        String   @id @default(uuid())
  userId    String
  topic     String
  theorem   String?
  problem   String
  solution  String
  errorType String
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MathSession {
  id           String    @id @default(uuid())
  userId       String
  startTime    DateTime  @default(now())
  endTime      DateTime?
  durationMins Int?
  focusScore   Int?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PracticeLog {
  id          String   @id @default(uuid())
  userId      String
  module      String
  type        String
  topic       String
  userInput   String
  aiFeedback  String
  score       Float?
  timeSpentMs Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MathTerm {
  id           String   @id @default(uuid())
  termRu       String
  termEn       String
  termDe       String
  definitionRu String
  formula      String?
  createdAt    DateTime @default(now())
}

model Algorithm {
  id          String          @id @default(uuid())
  title       String
  description String?
  formula     String?
  createdAt   DateTime        @default(now())
  steps       AlgorithmStep[]
}

model AlgorithmStep {
  id          String    @id @default(uuid())
  algorithmId String
  text        String
  math        String?
  order       Int
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)
}

model OrganizerTask {
  id        String    @id @default(uuid())
  userId    String
  text      String
  completed Boolean   @default(false)
  priority  String    @default("medium")
  deadline  DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizerHabit {
  id             String   @id @default(uuid())
  userId         String
  name           String
  completedDates String   @default("[]")
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

model TranslationCache {
  id              String   @id @default(uuid())
  word            String
  module          String
  translationData String
  createdAt       DateTime @default(now())

  @@unique([word, module])
  @@index([word])
}

model Broadcast {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  message   String
  context   String?
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([level])
  @@index([context])
  @@index([createdAt])
}
